# Optional: a Mapbox *public* access token (pk.*).
#
# When set, the examples render on a Mapbox basemap (dark-v11) instead of the
# default CARTO Dark Matter basemap. Leave it blank to run completely token-free.
#
# Get one at https://account.mapbox.com/access-tokens/
#
# To use locally: copy this file to `.env.local` and fill in the value.
VITE_MAPBOX_TOKEN=
