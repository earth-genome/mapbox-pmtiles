{
  "name": "@earthgenome/mapbox-pmtiles",
  "version": "0.1.1",
  "description": "Render PMTiles vector & raster sources in Mapbox GL JS — with first-class, framework-agnostic React helpers for react-map-gl and vanilla Mapbox apps.",
  "type": "module",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "mapbox",
    "mapbox-gl",
    "pmtiles",
    "react",
    "react-map-gl",
    "vector-tiles",
    "raster-tiles",
    "maps"
  ],
  "sideEffects": false,
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./react": {
      "types": "./dist/react/index.d.ts",
      "import": "./dist/react/index.js",
      "require": "./dist/react/index.cjs"
    },
    "./react-map-gl": {
      "types": "./dist/react-map-gl/index.d.ts",
      "import": "./dist/react-map-gl/index.js",
      "require": "./dist/react-map-gl/index.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run typecheck && npm run build",
    "release": "npm publish"
  },
  "peerDependencies": {
    "mapbox-gl": ">=3.0.0",
    "pmtiles": ">=3.0.0 <5",
    "react": ">=17.0.0",
    "react-map-gl": ">=7.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-map-gl": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "mapbox-gl": "^3.25.0",
    "pmtiles": "^4.4.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-map-gl": "^8.1.0",
    "tsup": "^8.5.0",
    "typescript": "^5.6.0"
  }
}
